# ===========================================
# Claw - 环境变量配置模板
# 复制此文件为 .env 并填入实际值
# cp .env.example .env
# ===========================================

# -------------------------------------------
# 应用基础配置
# -------------------------------------------

# 服务器端口（默认 5000）
PORT=5000

# 运行模式: development | production | test
NODE_ENV=development

# 前端 URL（用于 CORS 配置）
CLIENT_URL=http://localhost:5173

# -------------------------------------------
# 数据库配置
# -------------------------------------------

# MongoDB 连接字符串
# 本地开发:
MONGODB_URI=mongodb://localhost:27017/claw_dev

# Docker 环境:
# MONGODB_URI=mongodb://mongo:27017/claw_dev

# MongoDB Atlas 云数据库:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/claw_dev?retryWrites=true&w=majority

# -------------------------------------------
# JWT 认证配置
# -------------------------------------------

# JWT 密钥（生产环境请使用强随机密码，至少 32 字符）
JWT_SECRET=dev-secret-key-for-demo

# Token 过期时间（例如: 7d, 24h, 1h）
JWT_EXPIRE=7d

# -------------------------------------------
# 邮件服务配置（可选）
# -------------------------------------------

# SMTP 服务器地址
EMAIL_HOST=smtp.example.com

# SMTP 端口（587 for TLS, 465 for SSL, 25 for unencrypted）
EMAIL_PORT=587

# 是否使用 SSL/TLS
EMAIL_SECURE=false

# 发件邮箱账号
EMAIL_USER=your-email@example.com

# 发件邮箱密码或应用专用密码
EMAIL_PASS=your-app-password

# 发件人显示名称和邮箱
EMAIL_FROM="Claw System" <noreply@example.com>

# -------------------------------------------
# 文件上传配置
# -------------------------------------------

# 上传文件大小限制（字节），默认 10MB
MAX_FILE_SIZE=10485760

# 允许的文件类型（MIME 类型列表）
ALLOWED_FILE_TYPES=image/jpeg,image/png,application/pdf,.xlsx,.docx,.xls

# -------------------------------------------
# PDF 生成配置（可选）
# -------------------------------------------

# 自定义字体目录路径（用于 PDF 中文字体）
PDF_FONT_PATH=./fonts

# 默认字体文件名
PDF_FONT_NAME=NotoSansSC-Regular.ttf

# -------------------------------------------
# Demo 模式配置
# -------------------------------------------

# 是否启用 Demo 模式
# true: 允许未登录访问大部分功能（方便演示和测试）
# false: 所有功能需要登录
DEMO_MODE=true

# Demo 模式的默认用户 ID（用于模拟登录）
DEMO_USER_ID=660f8b9d8c9e4a0012345678

# -------------------------------------------
# 日志配置
# -------------------------------------------

# 日志级别: error | warn | info | debug
LOG_LEVEL=info

# 是否写入日志文件
LOG_TO_FILE=false

# 日志文件路径
LOG_FILE_PATH=./logs/app.log

# -------------------------------------------
# 安全配置（生产环境必填）
# -------------------------------------------

# CORS 允许的域名列表（逗号分隔）
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Rate Limiting - API 调用频率限制
RATE_LIMIT_WINDOW_MS=900000  # 15 分钟
RATE_LIMIT_MAX_REQUESTS=100   # 最大请求数

# -------------------------------------------
# 第三方服务（按需配置）
# -------------------------------------------

# AWS S3（用于云存储，如果不用本地存储）
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET_NAME=
# AWS_REGION=ap-east-1

# Redis（用于缓存和会话，可选）
# REDIS_URL=redis://localhost:6379
