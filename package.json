{
  "name": "company-secretary-management-system",
  "version": "2.0.0",
  "license": "MIT",
  "description": "A modern Company Secretary Management System",
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "server:dev": "nodemon --ignore .mongo-data --ignore .dev.log server/index.js",
    "client:dev": "cd client && npm run dev",
    "server:start": "node server/index.js",
    "client:build": "cd client && npm run build",
    "start": "node server/index.js",
    "setup": "node scripts/run-setup.js",
    "mongo:stop": "node scripts/run-stop-mongo.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1083.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "date-fns": "^3.0.6",
    "docxtemplater": "^3.68.3",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.7",
    "pdfkit": "^0.19.1",
    "pizzip": "^3.2.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
