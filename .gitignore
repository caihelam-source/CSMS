# ===========================================
# Claw - 公司秘书管理系统 .gitignore
# ===========================================

# Dependencies
node_modules/
client/node_modules/

# Local MongoDB data (one-click setup fallback)
.mongo-data/
.mongo-test/

# Build output
dist/
build/
client/dist/
client/build/

# Environment files
.env
.env.local
.env.*.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Coverage directory used by tools like istanbul
coverage/
*.lcov
.nyc_output/

# Uploads (user uploaded files)
uploads/*
!uploads/.gitkeep

# Temp files
temp/
tmp/
*.tmp
*.temp

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDE / Editor files
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Package manager lock files (可选是否提交)
# package-lock.json
# client/package-lock.json

# Docker volumes
docker-data/

# Backup files
*.bak
*.backup
output/

# Claude/WorkBuddy specific
.workbuddy/
.claude/

# Test results
test-results/
junit.xml

# Old backup directories
Claw_Company_Secretary_System/
output/
scripts/pdf_extracts/
*.zip

# Vite build temp config files
vite.config.js.timestamp-*
client/vite.config.js.timestamp-*
